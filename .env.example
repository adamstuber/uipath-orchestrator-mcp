# UiPath Orchestrator credentials
# Create an External Application in UiPath Automation Cloud (Admin > External Applications)
# and grant it the scopes listed below.

UIPATH_CLIENT_ID=your_client_id_here
UIPATH_CLIENT_SECRET=your_client_secret_here
UIPATH_TENANT_NAME=your_tenant_name_here
UIPATH_ORG_NAME=your_org_name_here

# Optional: override the default OAuth scopes
# UIPATH_SCOPES=OR.Jobs OR.Folders OR.Queues OR.Robots OR.Execution OR.Machines OR.Assets

# Optional: MCP transport
#   stdio            — default, for local MCP clients (Claude Desktop, Claude Code)
#   streamable-http  — recommended HTTP transport for Docker/remote deployments
#   sse              — legacy HTTP transport (older client compatibility)
# MCP_TRANSPORT=stdio

# Optional: SSE transport settings (only used when MCP_TRANSPORT=sse)
# MCP_HOST=0.0.0.0
# MCP_PORT=8000

# Optional: log level — DEBUG, INFO, WARN, ERROR (default: INFO)
# MCP_LOG_LEVEL=INFO
